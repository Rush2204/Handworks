---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Differentiators" currentPage="differentiators">
  <!-- HERO -->
  <section class="diff-hero">
    <div class="diff-hero-inner">
      <p class="eyebrow eyebrow-pink">WHY CHOOSE US</p>
      <h1 class="diff-hero-title">Key Differentiators</h1>
      <p class="diff-hero-desc">
        What sets Handworks apart is our unwavering commitment to quality, relationships,
        and continuous improvement in every aspect of our business.
      </p>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="diff-stats">
    <div class="diff-stats-inner">
      <div class="diff-stat">
        <div class="diff-stat-icon"><Icon name="lucide:globe" aria-hidden="true" /></div>
        <div class="diff-stat-num">Strategic Location</div>
        <div class="diff-stat-label">El Salvador, Central America</div>
      </div>
      <div class="diff-stat">
        <div class="diff-stat-icon"><Icon name="lucide:star" aria-hidden="true" /></div>
        <div class="diff-stat-num">25+ Years</div>
        <div class="diff-stat-label">Industry Experience</div>
      </div>
      <div class="diff-stat">
        <div class="diff-stat-icon"><Icon name="lucide:bar-chart-3" aria-hidden="true" /></div>
        <div class="diff-stat-num">40,000+</div>
        <div class="diff-stat-label">Monthly Capacity</div>
      </div>
      <div class="diff-stat">
        <div class="diff-stat-icon"><Icon name="lucide:check" aria-hidden="true" /></div>
        <div class="diff-stat-num">100%</div>
        <div class="diff-stat-label">U.S. Compliant</div>
      </div>
      <div class="diff-stat">
        <div class="diff-stat-icon"><Icon name="lucide:users" aria-hidden="true" /></div>
        <div class="diff-stat-num">25+</div>
        <div class="diff-stat-label">Team Members</div>
      </div>
      <div class="diff-stat">
        <div class="diff-stat-icon"><Icon name="lucide:crown" aria-hidden="true" /></div>
        <div class="diff-stat-num">Premium</div>
        <div class="diff-stat-label">Quality Standard</div>
      </div>
    </div>
  </section>

  <!-- DIFFERENTIATORS GRID -->
  <section class="diff-grid-section">
    <div class="diff-grid-inner">
      <div class="diff-grid">
        <article class="diff-card">
          <div class="diff-card-icon"><Icon name="lucide:map-pin" aria-hidden="true" /></div>
          <h3>El Salvador: A Textile Hub</h3>
          <ul class="diff-list">
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Strong textile heritage</strong>
                <p>Seasoned workforce with deep industry knowledge</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Proximity to the US</strong>
                <p>Shorter lead times for North American markets</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Favorable trade agreements</strong>
                <p>Improved pricing competitiveness</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Aligned time zones</strong>
                <p>Seamless communication with US clients</p>
              </div>
            </li>
          </ul>
        </article>

        <article class="diff-card">
          <div class="diff-card-icon"><Icon name="lucide:medal" aria-hidden="true" /></div>
          <h3>Consistent Premium Quality</h3>
          <ul class="diff-list">
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Reliable mills &amp; suppliers</strong>
                <p>Quality starts before production</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Skilled &amp; stable workforce</strong>
                <p>Precision-focused on every product</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Well-developed base patterns</strong>
                <p>Reducing sizing errors</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>25+ years in business</strong>
                <p>Full adherence to U.S. compliance and safety standards</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Multi-stage quality control</strong>
                <p>100% audit at the end of each productive line</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Quality as a system</strong>
                <p>Process optimization at every step</p>
              </div>
            </li>
          </ul>
        </article>

        <article class="diff-card">
          <div class="diff-card-icon"><Icon name="lucide:heart" aria-hidden="true" /></div>
          <h3>Relationship-Driven Manufacturing</h3>
          <ul class="diff-list">
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Customer satisfaction</strong>
                <p>Best measure of long-term, continued success</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Proactive communication</strong>
                <p>Clarity and predictability in every interaction</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Consistency and reliability</strong>
                <p>Stable quality, dependable timelines</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Mutual growth mindset</strong>
                <p>Retention over short-term goals</p>
              </div>
            </li>
          </ul>
        </article>

        <article class="diff-card">
          <div class="diff-card-icon"><Icon name="lucide:settings" aria-hidden="true" /></div>
          <h3>Refined Production Processes</h3>
          <ul class="diff-list">
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Structured pre-production planning</strong>
                <p>Clear production sequencing and reduced variability</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Precision pattern and sample development</strong>
                <p>Accurate foundations lead to excellent production</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Controlled cutting operations</strong>
                <p>Reducing waste and fitting integrity</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Workflow optimization</strong>
                <p>Minimizes errors and delays</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Continued process improvement</strong>
                <p>Sustained refinement over time</p>
              </div>
            </li>
          </ul>
        </article>

        <article class="diff-card">
          <div class="diff-card-icon"><Icon name="lucide:message-circle" aria-hidden="true" /></div>
          <h3>Transparent &amp; Responsive Communication</h3>
          <ul class="diff-list">
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Proactive updates</strong>
                <p>Consistent production visibility and early insights</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Rapid responsiveness</strong>
                <p>Timely communication supported by clear information</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Full transparency</strong>
                <p>Honest reporting of timelines, risks, and progress</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Structured communication</strong>
                <p>Defined contacts, reporting, and follow-through</p>
              </div>
            </li>
          </ul>
        </article>

        <article class="diff-card">
          <div class="diff-card-icon"><Icon name="lucide:layers" aria-hidden="true" /></div>
          <h3>In-stock Fabrics and Patterns</h3>
          <ul class="diff-list">
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Strategic inventory</strong>
                <p>Anticipating client needs rather than responding to them</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Reduced lead times</strong>
                <p>Ready-to-use materials for faster production</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Consistent availability</strong>
                <p>Reliable supply for ongoing projects</p>
              </div>
            </li>
            <li>
              <span class="diff-bullet"></span>
              <div>
                <strong>Cost efficiency</strong>
                <p>Bulk purchasing advantages passed to clients</p>
              </div>
            </li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- QUALITY & COMPLIANCE -->
  <section class="quality-section">
    <div class="quality-inner">
      <div class="quality-text">
        <p class="eyebrow eyebrow-pink">QUALITY ASSURANCE</p>
        <h2 class="section-title">Quality &amp; Compliance</h2>
        <p class="quality-desc">
          Our commitment to quality extends beyond the finished product. We maintain rigorous
          standards at every stage of production, ensuring full compliance with U.S. safety
          regulations and industry best practices.
        </p>
        <ul class="quality-list">
          <li>
            <span class="quality-icon"><Icon name="lucide:shirt" aria-hidden="true" /></span>
            <div>
              <strong>U.S. Compliance Expertise</strong>
              <p>Full adherence to U.S. safety standards and regulations for children's apparel.</p>
            </div>
          </li>
          <li>
            <span class="quality-icon"><Icon name="lucide:medal" aria-hidden="true" /></span>
            <div>
              <strong>Multi-Stage Quality Control</strong>
              <p>100% audit at the end of each production line and again at the first ship of packaging.</p>
            </div>
          </li>
          <li>
            <span class="quality-icon"><Icon name="lucide:flask-conical" aria-hidden="true" /></span>
            <div>
              <strong>Lab Testing Coordination</strong>
              <p>Comprehensive testing to ensure all materials and finished products meet safety requirements.</p>
            </div>
          </li>
        </ul>
      </div>
      <div class="quality-visual">
        <img 
    src="/images/calidad.jpg" 
    alt="Personal realizando control de calidad" 
    class="quality-image"
  />
        <div class="quality-badge">
          <div class="quality-badge-icon"><Icon name="lucide:check" aria-hidden="true" /></div>
          <div>
            <div class="quality-badge-num">100%</div>
            <div class="quality-badge-label">Quality Audited</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TOUR FACILITY -->
  <section class="tour-section">
    <div class="tour-inner">
      <div class="section-head">
        <p class="eyebrow eyebrow-pink">MANUFACTURING PROCESS</p>
        <h2 class="section-title">Tour Our Facility</h2>
        <p class="section-sub">
          Take a virtual tour through our state-of-the-art manufacturing facility and see how we bring
          designs to life.
        </p>
      </div>
      <div class="tour-image-wrap">
        <img 
    src="/images/equipo.jpg" 
    alt="Nuestras instalaciones de manufactura" 
    class="tour-image"
  />
        <a href="/contact" class="tour-cta">Schedule a Tour &rarr;</a>
      </div>
      <div class="process-steps">
        <div class="process-step"><span class="step-dot">1</span><span>Design</span></div>
        <div class="process-step"><span class="step-dot">2</span><span>Pattern</span></div>
        <div class="process-step"><span class="step-dot">3</span><span>Cutting</span></div>
        <div class="process-step"><span class="step-dot">4</span><span>Sewing</span></div>
        <div class="process-step"><span class="step-dot">5</span><span>Embroidery</span></div>
        <div class="process-step"><span class="step-dot">6</span><span>QC</span></div>
        <div class="process-step"><span class="step-dot">7</span><span>Finishing</span></div>
        <div class="process-step"><span class="step-dot">8</span><span>Packaging</span></div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials-section">
    <div class="testimonials-inner">
      <div class="section-head">
        <p class="eyebrow eyebrow-pink">CLIENT REVIEWS</p>
        <h2 class="section-title">What Our Partners Say</h2>
      </div>
      <div class="testimonials-grid">
        <article class="testimonial">
          <div class="testimonial-stars">
            <Icon name="lucide:star" aria-hidden="true" />
            <Icon name="lucide:star" aria-hidden="true" />
            <Icon name="lucide:star" aria-hidden="true" />
            <Icon name="lucide:star" aria-hidden="true" />
            <Icon name="lucide:star" aria-hidden="true" />
          </div>
          <p class="testimonial-quote">
            "Handworks has been an incredible partner. Their attention to detail and commitment to quality
            is unmatched in the industry."
          </p>
          <div class="testimonial-author">
            <strong>Sarah Mitchell</strong>
            <span>Children's Boutique Co.</span>
          </div>
        </article>
        <article class="testimonial">
          <div class="testimonial-stars">
            <Icon name="lucide:star" aria-hidden="true" />
            <Icon name="lucide:star" aria-hidden="true" />
            <Icon name="lucide:star" aria-hidden="true" />
            <Icon name="lucide:star" aria-hidden="true" />
            <Icon name="lucide:star" aria-hidden="true" />
          </div>
          <p class="testimonial-quote">
            "The team's expertise in embroidery has elevated our product line. Customers consistently praise
            the craftsmanship."
          </p>
          <div class="testimonial-author">
            <strong>Michael Chen</strong>
            <span>Little Stars Apparel</span>
          </div>
        </article>
        <article class="testimonial">
          <div class="testimonial-stars">
            <Icon name="lucide:star" aria-hidden="true" />
            <Icon name="lucide:star" aria-hidden="true" />
            <Icon name="lucide:star" aria-hidden="true" />
            <Icon name="lucide:star" aria-hidden="true" />
            <Icon name="lucide:star" aria-hidden="true" />
          </div>
          <p class="testimonial-quote">
            "Working with Handworks has transformed our supply chain. Their transparent communication
            makes everything seamless."
          </p>
          <div class="testimonial-author">
            <strong>Emma Rodriguez</strong>
            <span>Sunset Kids Fashion</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="diff-cta">
    <div class="diff-cta-inner">
      <h2>Experience the Handworks Difference</h2>
      <p>Ready to partner with a manufacturer who puts quality and relationships first? Let's discuss your project.</p>
      <div class="diff-cta-actions">
        <a href="/contact" class="btn-white">Request a Quote &rarr;</a>
        <a href="/services" class="btn-outline-white">Our Services</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Shared */
  .eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .eyebrow-pink {
    color: var(--color-pink);
  }
  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--color-teal);
    line-height: 1.15;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }
  .section-sub {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    max-width: 640px;
  }
  .image-placeholder {
    background: linear-gradient(135deg, #e8e2d8, #d8d0c4);
    border: 1px dashed rgba(14, 76, 90, 0.2);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(14, 76, 90, 0.4);
    font-size: 0.9rem;
    font-weight: 500;
    overflow: hidden;
  }
  .placeholder-label {
    pointer-events: none;
  }
  .section-head {
    text-align: center;
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .btn-white,
  .btn-outline-white {
    display: inline-block;
    padding: 0.85rem 1.8rem;
    border-radius: 999px;
    font-weight: 500;
    font-size: 0.95rem;
    text-decoration: none;
    transition: transform 0.3s, box-shadow 0.3s, background 0.3s, color 0.3s;
    border: 2px solid transparent;
    cursor: pointer;
  }
  .btn-white {
    background: #fff;
    color: var(--color-teal);
  }
  .btn-white:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }
  .btn-outline-white {
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
  }
  .btn-outline-white:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #fff;
  }

  /* HERO */
  .diff-hero {
    background: linear-gradient(135deg, var(--color-teal) 0%, var(--color-teal-light) 100%);
    color: #fff;
    padding: 5rem 2.5rem 6rem;
  }
  .diff-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .diff-hero .eyebrow {
    color: var(--color-pink-light);
  }
  .diff-hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.1;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }
  .diff-hero-desc {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.1rem;
    max-width: 640px;
  }

  /* STATS */
  .diff-stats {
    background: var(--color-bg);
    padding: 2.5rem 2.5rem;
    border-bottom: 1px solid rgba(14, 76, 90, 0.06);
  }
  .diff-stats-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  .diff-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .diff-stat-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--color-teal);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.4rem;
  }
  .diff-stat-icon svg {
    width: 22px;
    height: 22px;
    stroke-width: 1.75;
  }
  .diff-stat-num {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-teal);
    line-height: 1.15;
  }
  .diff-stat-label {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  /* DIFFERENTIATORS GRID */
  .diff-grid-section {
    padding: 5rem 2.5rem;
  }
  .diff-grid-inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  .diff-card {
    background: #fff;
    border-radius: 20px;
    padding: 2.25rem 2rem;
    box-shadow: 0 4px 20px rgba(14, 76, 90, 0.05);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .diff-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(14, 76, 90, 0.1);
  }
  .diff-card-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: var(--color-teal);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  .diff-card-icon svg {
    width: 26px;
    height: 26px;
    stroke-width: 1.75;
  }
  .diff-card h3 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--color-teal);
    margin-bottom: 1.25rem;
    font-weight: 600;
  }
  .diff-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .diff-list li {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .diff-bullet {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-pink);
    flex-shrink: 0;
    margin-top: 0.55rem;
  }
  .diff-list strong {
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 600;
    display: block;
    margin-bottom: 0.15rem;
  }
  .diff-list p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  /* QUALITY */
  .quality-section {
    padding: 5rem 2.5rem;
    background: var(--color-section-gray);
  }
  .quality-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .quality-desc {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
  .quality-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .quality-list li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .quality-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--color-teal);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .quality-icon svg {
    width: 20px;
    height: 20px;
    stroke-width: 1.75;
  }
  .quality-list strong {
    color: var(--color-teal);
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    display: block;
    margin-bottom: 0.2rem;
  }
  .quality-list p {
    color: var(--color-text-muted);
    font-size: 0.92rem;
  }
  .quality-visual {
    position: relative;
    aspect-ratio: 4 / 3;
  }
  .quality-image {
    width: 100%;
    height: 100%;
    border-radius: 20px;
  object-fit: cover; /* Añade esto */
  display: block;
  }
  .quality-badge {
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    background: #fff;
    border-radius: 14px;
    padding: 0.85rem 1.4rem;
    box-shadow: 0 12px 30px rgba(14, 76, 90, 0.12);
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .quality-badge-icon {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: var(--color-teal);
