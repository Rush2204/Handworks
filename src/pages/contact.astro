---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Contact" currentPage="contact">
  <!-- HERO -->
  <section class="contact-hero">
    <div class="contact-hero-inner">
      <p class="eyebrow eyebrow-pink-light">GET IN TOUCH</p>
      <h1 class="contact-hero-title">Contact Us</h1>
      <p class="contact-hero-description">
        Ready to start your project? We'd love to hear from you. Fill out the form below or
        reach out directly.
      </p>
    </div>
  </section>

  <!-- CONTACT FORM + INFO -->
  <section class="contact-section">
    <div class="contact-section-inner">
      <!-- Form -->
      <div class="contact-form-card">
        <h2 class="form-title">Request a Quote</h2>
        <p class="form-sub">Tell us about your project and we'll get back to you within 24 hours.</p>
        <form class="contact-form">
          <div class="form-row">
            <div class="form-field">
              <label for="full-name">Full Name *</label>
              <input id="full-name" type="text" placeholder="John Doe" required />
            </div>
            <div class="form-field">
              <label for="email">Email Address *</label>
              <input id="email" type="email" placeholder="john@company.com" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-field">
              <label for="company">Company Name</label>
              <input id="company" type="text" placeholder="Your Company" />
            </div>
            <div class="form-field">
              <label for="phone">Phone Number</label>
              <input id="phone" type="tel" placeholder="+1 (555) 000-0000" />
            </div>
          </div>
          <div class="form-field">
            <label for="inquiry">Inquiry Type *</label>
            <select id="inquiry" required>
              <option value="" disabled selected>Select inquiry type</option>
              <option value="quote">Request a Quote</option>
              <option value="tour">Schedule a Tour</option>
              <option value="catalog">View Catalog</option>
              <option value="samples">Sample Request</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-field">
            <label for="message">Message *</label>
            <textarea id="message" rows="5" placeholder="Tell us about your project, requirements, and timeline..." required></textarea>
          </div>
          <button type="submit" class="btn-primary form-submit">
            <Icon name="lucide:send" class="submit-icon" aria-hidden="true" />
            Send Message
          </button>
        </form>
      </div>

      <!-- Info -->
      <div class="contact-info">
        <ul class="info-list">
          <li class="info-item">
            <div class="info-icon"><Icon name="lucide:map-pin" aria-hidden="true" /></div>
            <div>
              <h3>Location</h3>
              <p>El Salvador, Central America</p>
            </div>
          </li>
          <li class="info-item">
            <div class="info-icon"><Icon name="lucide:phone" aria-hidden="true" /></div>
            <div>
              <h3>Phone</h3>
              <p>+503 1234 5678</p>
            </div>
          </li>
          <li class="info-item">
            <div class="info-icon"><Icon name="lucide:mail" aria-hidden="true" /></div>
            <div>
              <h3>Email</h3>
              <p>info@handworks.com</p>
              <p>sales@handworks.com</p>
            </div>
          </li>
          <li class="info-item">
            <div class="info-icon"><Icon name="lucide:clock" aria-hidden="true" /></div>
            <div>
              <h3>Business Hours</h3>
              <p>Monday - Friday: 8:00 AM - 5:00 PM</p>
              <p>Saturday - Sunday: Closed</p>
            </div>
          </li>
        </ul>

        <div class="map-card image-placeholder">
          <div class="map-pin"><Icon name="lucide:map-pin" aria-hidden="true" /></div>
          <p class="map-title">El Salvador, Central America</p>
          <p class="map-sub">Strategic location for US market access</p>
        </div>
      </div>
    </div>
  </section>

  <!-- QUICK ACTIONS -->
  <section class="quick-actions">
    <div class="quick-inner">
      <div class="section-head">
        <p class="eyebrow eyebrow-pink">QUICK ACTIONS</p>
        <h2 class="section-title">How Can We Help?</h2>
      </div>
      <div class="quick-grid">
        <article class="quick-card">
          <h3>Request a Quote</h3>
          <p>Get pricing for your project with detailed specifications.</p>
          <a href="#" class="link-arrow">Get Quote &rarr;</a>
        </article>
        <article class="quick-card">
          <h3>Schedule a Tour</h3>
          <p>Visit our facility and see our manufacturing process.</p>
          <a href="#" class="link-arrow">Book Tour &rarr;</a>
        </article>
        <article class="quick-card">
          <h3>View Catalog</h3>
          <p>Browse our product catalog and fabric options.</p>
          <a href="#" class="link-arrow">View Catalog &rarr;</a>
        </article>
        <article class="quick-card">
          <h3>Sample Request</h3>
          <p>Request product samples to evaluate quality.</p>
          <a href="#" class="link-arrow">Request Samples &rarr;</a>
        </article>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq">
    <div class="faq-inner">
      <div class="section-head">
        <p class="eyebrow eyebrow-pink">FAQ</p>
        <h2 class="section-title">Frequently Asked Questions</h2>
      </div>
      <div class="faq-list">
        <article class="faq-item">
          <h3>What is your minimum order quantity?</h3>
          <p>Our minimum order quantity varies depending on the product type and complexity. We accommodate both small boutique runs and large-scale production. Contact us to discuss your specific needs.</p>
        </article>
        <article class="faq-item">
          <h3>What are your typical lead times?</h3>
          <p>Lead times depend on order size and complexity. Generally, sampling takes 2-3 weeks, and production runs range from 4-8 weeks. We prioritize clear communication about timelines throughout the process.</p>
        </article>
        <article class="faq-item">
          <h3>Do you offer custom design services?</h3>
          <p>Yes, we offer comprehensive design and development services including concept support, tech pack creation, pattern making, and prototyping. Our team can help bring your vision to life.</p>
        </article>
        <article class="faq-item">
          <h3>What quality standards do you maintain?</h3>
          <p>We maintain full U.S. compliance and safety standards for children's apparel. Our multi-stage quality control includes 100% audit at the end of each production line and lab testing coordination.</p>
        </article>
        <article class="faq-item">
          <h3>Can I visit your facility?</h3>
          <p>Absolutely! We welcome facility tours for potential partners. Contact us to schedule a visit and see our manufacturing process firsthand.</p>
        </article>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Shared */
  .eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .eyebrow-pink {
    color: var(--color-pink);
  }
  .eyebrow-pink-light {
    color: var(--color-pink-light);
  }
  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--color-teal);
    line-height: 1.15;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }
  .section-head {
    text-align: center;
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .image-placeholder {
    background: linear-gradient(#f3efe9);
    border: 1px dashed rgba(14, 76, 90, 0.2);
    border-radius: 16px;
    overflow: hidden;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.95rem 1.8rem;
    border-radius: 999px;
    font-weight: 500;
    font-size: 0.95rem;
    text-decoration: none;
    transition: transform 0.3s, box-shadow 0.3s, background 0.3s;
    border: 2px solid transparent;
    cursor: pointer;
    background: var(--color-teal);
    color: #fff;
  }
  .btn-primary:hover {
    background: var(--color-teal-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(14, 76, 90, 0.25);
  }
  .link-arrow {
    color: var(--color-teal);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: gap 0.3s;
  }
  .link-arrow:hover {
    gap: 0.7rem;
  }

  /* HERO */
  .contact-hero {
    background: linear-gradient(135deg, var(--color-teal) 0%, var(--color-teal-light) 100%);
    color: #fff;
    padding: 4.5rem 2.5rem 5rem;
  }
  .contact-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .contact-hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 3.8rem);
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    color: #fff;
  }
  .contact-hero-description {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.05rem;
    max-width: 560px;
    line-height: 1.6;
  }

  /* CONTACT SECTION */
  .contact-section {
    padding: 5rem 2.5rem;
  }
  .contact-section-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* FORM */
  .contact-form-card {
    background: var(--color-bg-soft);
    border-radius: 20px;
    padding: 2.5rem;
  }
  .form-title {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    color: var(--color-teal);
    font-weight: 600;
    margin-bottom: 0.4rem;
  }
  .form-sub {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.75rem;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .form-field label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .form-field input,
  .form-field select,
  .form-field textarea {
    background: #fff;
    border: 1px solid rgba(14, 76, 90, 0.12);
    border-radius: 10px;
    padding: 0.75rem 0.95rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-text);
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 90%;
  }
  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-teal);
    box-shadow: 0 0 0 3px rgba(14, 76, 90, 0.1);
  }
  .form-field textarea {
    resize: vertical;
    min-height: 120px;
    font-family: var(--font-sans);
  }
  .form-submit {
    width: 100%;
    margin-top: 0.5rem;
  }
  .submit-icon {
    width: 18px;
    height: 18px;
    stroke-width: 2;
    vertical-align: middle;
    margin-right: 0.4rem;
  }

  /* INFO */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .info-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .info-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .info-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--color-teal);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .info-icon svg {
    width: 20px;
    height: 20px;
    stroke-width: 1.75;
  }
  .info-item h3 {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--color-teal);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .info-item p {
    color: var(--color-text-muted);
    font-size: 0.93rem;
    line-height: 1.5;
  }

  /* MAP */
  .map-card {
    aspect-ratio: 16 / 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }
  .map-pin {
    color: var(--color-pink);
    margin-bottom: 0.75rem;
    display: flex;
    justify-content: center;
  }
  .map-pin svg {
    width: 40px;
    height: 40px;
    stroke-width: 1.75;
  }
  .map-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--color-teal);
    font-weight: 600;
    margin-bottom: 0.3rem;
  }
  .map-sub {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  /* QUICK ACTIONS */
  .quick-actions {
    background: var(--color-section-gray);
    padding: 6rem 2.5rem;
  }
  .quick-inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .quick-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .quick-card {
    background: #fff;
    border-radius: 16px;
    padding: 2rem 1.75rem;
    transition: transform 0.3s, box-shadow 0.3s;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .quick-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(14, 76, 90, 0.08);
  }
  .quick-card h3 {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    color: var(--color-teal);
    font-weight: 600;
  }
  .quick-card p {
    color: var(--color-text-muted);
    font-size: 0.93rem;
    flex: 1;
  }
  .quick-card .link-arrow {
    margin-top: 0.5rem;
  }

  /* FAQ */
  .faq {
    padding: 6rem 2.5rem;
  }
  .faq-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .faq-item {
    background: var(--color-bg-soft);
    border-radius: 14px;
    padding: 1.5rem 1.75rem;
  }
  .faq-item h3 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--color-teal);
    font-weight: 600;
    margin-bottom: 0.6rem;
  }
  .faq-item p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* RESPONSIVE */
  @media (max-width: 980px) {
    .contact-section-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .quick-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .contact-hero {
      padding: 3.5rem 1.25rem 4rem;
    }
    .contact-section,
    .quick-actions,
    .faq {
      padding: 4rem 1.25rem;
    }
    .contact-form-card {
      padding: 1.75rem;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
    .quick-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
