# ============================================================
# SMTP credentials used by /src/pages/api/send-quote.ts
# ============================================================
# Defaults below are for Gmail SMTP. To use Gmail you must:
#  1. Enable 2-Step Verification on your Google account.
#  2. Generate an App Password: https://myaccount.google.com/apppasswords
#  3. Paste the 16-character app password as SMTP_PASSWORD (no spaces).
#
# To switch providers (Brevo, Mailgun, SES, custom) just change
# SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASSWORD — no code change.
# ------------------------------------------------------------

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-account@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# Where the contact form messages are delivered.
CONTACT_RECIPIENT=your-account@gmail.com

# "From" address shown in the inbox. Many providers require this
# to match SMTP_USER (Gmail rewrites mismatched senders).
MAIL_FROM="Handworks Website <your-account@gmail.com>"
